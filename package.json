    "@tiptap/vue-3": "^3.26.1",
    "axios": "^1.17.0",
    "axios-retry": "^4.5.0",
    "dompurify": "^3.4.11",
    "lucide-vue-next": "^1.0.0",
    "pinia": "^3.0.4",
    "quill": "^2.0.3",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/dompurify": "^3.0.5",
